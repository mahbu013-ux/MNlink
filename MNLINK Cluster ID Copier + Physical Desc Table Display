// ==UserScript==
// @name        MNLINK Cluster ID Copier + Physical Disc Table Row
// @namespace   Minitex
// @version     1.1
// @description Extracts and copies record ID from MNLink URLs upon element availability + allows physical description info to be easier to access
// @match       https://search.mnlink.org/*
// @grant       none
// ==/UserScript==

(function() {
    'use strict';

    // Function to extract and copy ID to clipboard
function copyIDToClipboard() {
    const url = window.location.href;
    const match = url.match(/Record\/([^/?]+)/);
    if (match && match[1]) {
        navigator.clipboard.writeText(match[1]).then(() => {
            console.log('Record ID copied to clipboard:', match[1]);
            alert('Record ID copied to clipboard: ' + match[1]);
        }).catch(err => {
            console.error('Failed to copy text: ', err);
        });
    }
}

    // Attempt to add the button to the page
    function addButton() {
        const permalinkButton = document.querySelector('a.permalink-record.toolbar-btn');
        if (permalinkButton) {
            const button = document.createElement('button');
            button.textContent = 'Copy Record ID';
            button.style.marginLeft = '10px';
            button.onclick = copyIDToClipboard;
            permalinkButton.parentNode.insertBefore(button, permalinkButton.nextSibling);
            console.log('Button added successfully.');
        } else {
            console.log('Permalink button not found.');
        }
    }

    // Check if the permalink button exists, if not, use MutationObserver
    if (document.querySelector('a.permalink-record.toolbar-btn')) {
        addButton();
    } else {
        // Observer to track DOM changes
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.addedNodes.length) {
                    addButton();
                    observer.disconnect(); // Stop observing once the button is added
                }
            });
        });

        // Start observing the DOM
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });
    }
})();




// addition

// 1. Emulate single user click on the description tab (to load physical description)
(function() {
    'use strict';

    if (window.__mnlinkPhysicalDescInjected) {
        return;
    }
    window.__mnlinkPhysicalDescInjected = true;

    const descButton = Array.from(document.querySelectorAll('#tabnav a, .nav-tabs a'))
        .find(el => el.textContent.trim().toLowerCase().includes('description'));

    if (descButton && !sessionStorage.getItem('tabClicked')) {
        sessionStorage.setItem('tabClicked', 'true');
        descButton.click();
    }

    requestAnimationFrame(() => {
        window.scrollTo(0, 0);
    });

    // Inserts the physical description into the metadata table before the Language row.
    function tryInsert() {
        const headers = Array.from(document.querySelectorAll('th'));
        const table = document.querySelector('table.table.table-striped');
        if (!table) return false;

        const labelEl = headers.find(el => el.textContent.trim().includes('Physical Description:'));
        if (!labelEl) return false;

        const physdiscValue = labelEl.nextElementSibling?.textContent?.trim();
        if (!physdiscValue) return false;

        const languageRow = Array.from(table.querySelectorAll('tr')).find(row => {
            const cells = Array.from(row.querySelectorAll('th, td'));
            return cells.some(cell => cell.textContent.trim().toLowerCase().includes('language'));
        });

        if (!languageRow) return false;

        const existingRow = Array.from(table.querySelectorAll('tr')).find(row => {
            const cells = Array.from(row.querySelectorAll('th, td'));
            return cells.some(cell => cell.textContent.trim().toLowerCase().includes('physical description'));
        });

        if (existingRow) {
            existingRow.querySelector('td, th:last-child')?.remove();
        }

        const newRow = document.createElement('tr');
        const newLabel = document.createElement('th');
        newLabel.textContent = 'Physical Description';
        const newValue = document.createElement('td');
        newValue.textContent = physdiscValue;
        newRow.appendChild(newLabel);
        newRow.appendChild(newValue);

        languageRow.parentNode.insertBefore(newRow, languageRow);
        console.log('Tampermonkey: Success! Inserted description into table:', physdiscValue);
        sessionStorage.removeItem('tabClicked');
        return true;
    }

    // Poll to allow AJAX time to fetch data, but stop once the field is clearly absent.
    let attempts = 0;
    const maxAttempts = 20;
    const checkExist = window.setInterval(() => {
        attempts += 1;

        if (tryInsert()) {
            window.clearInterval(checkExist);
            console.log('Tampermonkey: Loop cleared successfully.');
            return;
        }

        if (attempts >= maxAttempts) {
            window.clearInterval(checkExist);
            sessionStorage.removeItem('tabClicked');
            console.log('Tampermonkey: No physical description found after polling; stopping.');
        }
    }, 300);
})();
