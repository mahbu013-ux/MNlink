// ==UserScript==
// @name        MNLINK Cluster ID Copier + Physical Disc Para
// @namespace   Minitex
// @version     1.1
// @description Extracts and copies record ID from MNLink URLs upon element availability + allows physical description info to be easier to access
// @match       https://search.mnlink.org/*
// @grant       none
// ==/UserScript==

(function() {
    'use strict';

    // Function to extract and copy ID to clipboard
function copyIDToClipboard() {
    const url = window.location.href;
    const match = url.match(/Record\/([^/?]+)/);
    if (match && match[1]) {
        navigator.clipboard.writeText(match[1]).then(() => {
            console.log('Record ID copied to clipboard:', match[1]);
            alert('Record ID copied to clipboard: ' + match[1]);
        }).catch(err => {
            console.error('Failed to copy text: ', err);
        });
    }
}

    // Attempt to add the button to the page
    function addButton() {
        const permalinkButton = document.querySelector('a.permalink-record.toolbar-btn');
        if (permalinkButton) {
            const button = document.createElement('button');
            button.textContent = 'Copy Record ID';
            button.style.marginLeft = '10px';
            button.onclick = copyIDToClipboard;
            permalinkButton.parentNode.insertBefore(button, permalinkButton.nextSibling);
            console.log('Button added successfully.');
        } else {
            console.log('Permalink button not found.');
        }
    }

    // Check if the permalink button exists, if not, use MutationObserver
    if (document.querySelector('a.permalink-record.toolbar-btn')) {
        addButton();
    } else {
        // Observer to track DOM changes
        const observer = new MutationObserver((mutations) => {
            mutations.forEach((mutation) => {
                if (mutation.addedNodes.length) {
                    addButton();
                    observer.disconnect(); // Stop observing once the button is added
                }
            });
        });

        // Start observing the DOM
        observer.observe(document.body, {
            childList: true,
            subtree: true
        });
    }
})();




// addition

// 1. Emulate single user click on the description tab (to load physical description)
(function() {
    'use strict';

    const pageKeyName = '__mnlinkPhysicalDescPage';
    let pendingNavigationReset = null;

    function getCurrentPageKey() {
        return window.location.href.split('#')[0];
    }

    function shouldRunForCurrentPage() {
        return window[pageKeyName] !== getCurrentPageKey();
    }

    function markCurrentPageProcessed() {
        window[pageKeyName] = getCurrentPageKey();
    }

    function initializePhysicalDescription() {
        if (!shouldRunForCurrentPage()) {
            return;
        }

        markCurrentPageProcessed();
        sessionStorage.removeItem('tabClicked');

        const descButton = Array.from(document.querySelectorAll('#tabnav a, .nav-tabs a'))
            .find(el => el.textContent.trim().toLowerCase().includes('description'));

        if (descButton && !sessionStorage.getItem('tabClicked')) {
            sessionStorage.setItem('tabClicked', 'true');
            descButton.click();
        }

        requestAnimationFrame(() => {
            window.scrollTo(0, 0);
        });

// Inserts the physical description into the target paragraph & creates target paragraph if it doesn't exist
function tryInsert() {
    const headers = Array.from(document.querySelectorAll('th'));
    const mediaBody = document.querySelector('.media-body');
    if (!mediaBody) return false;

    let targetPlacement = mediaBody.querySelector('p:first-of-type');
    if (!targetPlacement) {
        targetPlacement = document.createElement('p');
        const referenceElement = mediaBody.querySelector('table, ul, div, .table-responsive');
        if (referenceElement) {
            mediaBody.insertBefore(targetPlacement, referenceElement);
        } else {
            mediaBody.appendChild(targetPlacement);
        }
    }

    const labelEl = headers.find(el => el.textContent.trim().includes('Physical Description:'));

    if (labelEl && targetPlacement) {
        const physdiscValue = labelEl.nextElementSibling?.textContent;
        if (physdiscValue) {
            console.log("Tampermonkey: Success! Found description:", physdiscValue.trim());
            targetPlacement.innerText = physdiscValue.trim();
            sessionStorage.removeItem('tabClicked');
            return true;
        }
    }
    return false;
}

        // Poll to allow AJAX time to fetch data, but stop once the field is clearly absent.
        let attempts = 0;
        const maxAttempts = 20;
        const checkExist = window.setInterval(() => {
            attempts += 1;

            if (tryInsert()) {
                window.clearInterval(checkExist);
                console.log('Tampermonkey: Loop cleared successfully.');
                return;
            }

            if (attempts >= maxAttempts) {
                window.clearInterval(checkExist);
                sessionStorage.removeItem('tabClicked');
                console.log('Tampermonkey: No physical description found after polling; stopping.');
            }
        }, 300);
    }

    function scheduleReinitialize() {
        if (pendingNavigationReset) {
            window.clearTimeout(pendingNavigationReset);
        }

        pendingNavigationReset = window.setTimeout(() => {
            pendingNavigationReset = null;
            initializePhysicalDescription();
        }, 600);
    }

    const pagerSelector = [
        'a[rel="next"]',
        'a[rel="prev"]',
        'a[rel="previous"]',
        'a[title*="Next"]',
        'a[title*="Previous"]',
        'a[aria-label*="Next"]',
        'a[aria-label*="Previous"]',
        '.pager a',
        '.pagination a'
    ].join(',');

    document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest(pagerSelector) : null;
        if (!target) return;

        const label = `${target.textContent || ''} ${target.getAttribute('aria-label') || ''} ${target.getAttribute('title') || ''}`.toLowerCase();
        if (label.includes('next') || label.includes('prev') || label.includes('previous')) {
            scheduleReinitialize();
        }
    }, true);

    const originalPushState = window.history.pushState;
    window.history.pushState = function(...args) {
        const result = originalPushState.apply(this, args);
        scheduleReinitialize();
        return result;
    };

    const originalReplaceState = window.history.replaceState;
    window.history.replaceState = function(...args) {
        const result = originalReplaceState.apply(this, args);
        scheduleReinitialize();
        return result;
    };

    window.addEventListener('popstate', scheduleReinitialize);

    const observer = new MutationObserver(() => {
        if (document.querySelector('table.table.table-striped') && shouldRunForCurrentPage()) {
            initializePhysicalDescription();
        }
    });
    observer.observe(document.body, { childList: true, subtree: true });

    initializePhysicalDescription();
})();
